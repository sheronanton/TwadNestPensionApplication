<?xml version="1.0"?>
<!DOCTYPE hibernate-mapping PUBLIC "-//Hibernate/Hibernate Mapping DTD 3.0//EN"
"http://hibernate.sourceforge.net/hibernate-mapping-3.0.dtd">

<hibernate-mapping>
    <class name="com.nic.hrms.pension.model.ChangeNominee_dao" table="HRM_PEN_CHANGE_NOMINEE">
      
       <id name="nomineeID" type="integer"   >
            <column name="NOMINEE_ID"  />
            <generator class="assigned" />
        </id>
       
        <property name="ppoNo" type="integer">
            <column name="PPO_NO" length="6" />
        </property>
        
		<property name="nomineeInitial" type="string">
            <column name="NOMINEE_INITIAL" length="10" />
        </property>
        
		<property name="familyMembers" type="string">
            <column name="NOMINEE_NAME" length="50" />
        </property>
        
             <property name="relation" type="string">
            <column name="RELATIONSHIP_ID" length="2" />
        </property>
        
        <property name="dob" type="date">
            <column name="DOB" />
        </property>
        <property name="age" type="integer">
            <column name="AGE"  length="6"/>
        </property>
         <property name="maritalStatus" type="string">
            <column name="MARITAL_STATUS" length="1" />
        </property>
         <property name="handicapped" type="string">
            <column name="HANDICAPPED" length="1" />
        </property>
           <property name="nominationDate" type="date">
            <column name="NOMINATION_DATE"  />
        </property>
           <property name="deletedReason" type="string">
            <column name="IS_DELETED_REASON" length="250" />
        </property>
         <property name="updatedDate" type="java.sql.Timestamp">
            <column name="UPDATED_DATE"  />
        </property>
         <property name="updatedBy" type="string">
            <column name="UPDATED_USER"  />
        </property>
          
        <property name="unlockedBy" type="string">
        <column name="UNLOCKED_BY" length="15" />
        </property>
        
        <property name="unlockedDate" type="java.sql.Timestamp">
        <column name="UNLOCKED_DATE" />
        </property>

        <property name="processStatus" type="string">
        <column name="PROCESS_STATUS" length="10" />
        </property>                
          
        </class>             
     
</hibernate-mapping>
