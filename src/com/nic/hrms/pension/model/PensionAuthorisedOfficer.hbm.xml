<?xml version="1.0"?>
<!DOCTYPE hibernate-mapping PUBLIC
	"-//Hibernate/Hibernate Mapping DTD 3.0//EN"
	"http://hibernate.sourceforge.net/hibernate-mapping-3.0.dtd">
<hibernate-mapping>

	<class name="com.nic.hrms.pension.model.PensionAuthorisedOfficer_dao" table="HRM_PEN_APP_AUTHORISE_OFF_MST">
		
		<id name="authorisedOfficerId" type="integer"  >
            <column name="AUTHORIZATION_ID"  />
            <generator class="assigned" />
        </id>
        
		<property name="authorisedOfficerDesc" type="string">
			<column name="AUTHORIZATION_DESC" length="250" />
		</property>		
	
	</class>
</hibernate-mapping>	
