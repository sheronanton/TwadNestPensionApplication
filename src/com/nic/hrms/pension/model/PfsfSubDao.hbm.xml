<?xml version="1.0"?>
<!DOCTYPE hibernate-mapping PUBLIC
	"-//Hibernate/Hibernate Mapping DTD 3.0//EN"
	"http://hibernate.sourceforge.net/hibernate-mapping-3.0.dtd">
<hibernate-mapping>
<class name="com.nic.hrms.pension.model.PfsfSubDao" table="HRM_PEN_PFSF_SUBS">
	
		<id name="ppoNo" type="integer"  >
    		<column name="PPO_NO"  length="6" />
        	<generator class="assigned" />
   		 </id>
        
    	<property name="updatedUsedId" type="string">
			<column name="UPDATED_USER_ID" length="20"/>
		</property>
		
		<property name="updatedDate" type="java.sql.Timestamp">
			<column name="UPDATED_DATE" />
		</property>				
				
		<property name="processStatus" type="string">
			<column name="PROCESS_STATUS" length="10"/>
		</property>
		
		<property name="unlockedBy" type="string">
			<column name="UNLOCKED_BY" length="15"/>
		</property>
		
		<property name="unlockedDate" type="java.sql.Timestamp">
			<column name="UNLOCKED_DATE" />
		</property>    
        
      </class>  
</hibernate-mapping>