					<textElement textAlignment="Center" verticalAlignment="Middle">
						<font pdfFontName="Helvetica-Bold" size="12" isBold="true"/>
					</textElement>
				<text><![CDATA[LETTER OF CONSENT FOR RECOVERY]]></text>
				</staticText>
			</band>
		</title>
		<pageHeader>
			<band height="0"  isSplitAllowed="true" >
			</band>
		</pageHeader>
		<columnHeader>
			<band height="0"  isSplitAllowed="true" >
			</band>
		</columnHeader>
		<detail>
			<band height="227"  isSplitAllowed="true" >
				<staticText>
					<reportElement
						x="276"
						y="185"
						width="251"
						height="20"
						key="staticText-6"/>
					<box></box>
					<textElement textAlignment="Center">
						<font pdfFontName="Helvetica-Bold" size="12" isBold="true"/>
					</textElement>
				<text><![CDATA[SIGNATURE OF THE APPLICANT]]></text>
				</staticText>
				<staticText>
					<reportElement
						x="1"
						y="29"
						width="524"
						height="95"
						key="staticText-9"/>
					<box></box>
					<textElement textAlignment="Justified">
						<font pdfFontName="Helvetica-Bold" size="12" isBold="true"/>
					</textElement>
				<text><![CDATA[hereby certify that as per G.O.Ms.No. 845, Finance (Pension) Department Dated 29.10.55, I am willing to make good the loss caused to Board by way of any over drawl of pay, allowances, leave salary or either admitted obvious dues as a result of negligence or fraud on any part while in service in Department in a lump sum or in suitable instalment from my pension or Gratuity.]]></text>
				</staticText>
				<staticText>
					<reportElement
						x="1"
						y="12"
						width="17"
						height="18"
						key="staticText-10"/>
					<box></box>
					<textElement>
						<font pdfFontName="Helvetica-Bold" size="12" isBold="true"/>
					</textElement>
				<text><![CDATA[I]]></text>
				</staticText>
				<textField isStretchWithOverflow="false" isBlankWhenNull="true" evaluationTime="Now" hyperlinkType="None"  hyperlinkTarget="Self" >
					<reportElement
						x="20"
