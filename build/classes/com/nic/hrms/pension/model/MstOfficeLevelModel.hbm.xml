<?xml version="1.0"?>
<!DOCTYPE hibernate-mapping PUBLIC
	"-//Hibernate/Hibernate Mapping DTD 3.0//EN"
	"http://hibernate.sourceforge.net/hibernate-mapping-3.0.dtd">
<hibernate-mapping>

	
	<class name="com.nic.hrms.pension.model.MstOfficeLevelModel" table="COM_MST_OFFICE_LEVELS">
		
		<id name="office_level_id" type="char">
			<column name="OFFICE_LEVEL_ID" length="2" />
			<generator class="assigned" />
		</id>
		
		<property name="office_level_name" type="string" >
			<column name="OFFICE_LEVEL_NAME" length="20"/>
		</property>
		
		<property name="office_head_cadre_id" type="integer">
			<column name="OFFICE_HEAD_CADRE_ID" length="3"/>
		</property>
		
		<property name="hierarchical_sequence" type="integer">
			<column name="HIERARCHICAL_SEQUENCE" length="2"/>
		</property>
		
		<property name="hierachical_view_name" type="string">
			<column name="HIERACHICAL_VIEW_NAME" length="30"/>
		</property>
		
		<property name="remarks" type="string">
			<column name="REMARKS" length="200"/>
		</property>
		
		<property name="updated_by_user_id" type="string" >
			<column name="UPDATED_BY_USER_ID" length="20"/>
		</property>
		
		<property name="updated_date" type="date" >
			<column name="UPDATED_DATE" />
		</property>
	</class>
	



</hibernate-mapping>